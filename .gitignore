# ==========================================
# 1. 机密信息与配置文件 (⚠️ 最重要：绝对不能提交！)
# ==========================================
.env
*.pem
secrets.json

# ==========================================
# 2. 本地数据库与状态文件 (避免污染远程仓库)
# ==========================================
*.db
*.sqlite3
*.db-journal
enterprise_agent_state.db
enterprise_agent_state.db-journal

# ==========================================
# 3. Python 虚拟环境
# ==========================================
venv/
env/
.venv/

# ==========================================
# 4. Python 编译与运行缓存
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/

# ==========================================
# 5. 业务产生的临时文件或测试文档 (按需调整)
# ==========================================
# 假设未来你会建这些文件夹来放测试用的 Excel 或 Word
/test_docs/
/extracted_images/
*.log
/tmp/

# ==========================================
# 6. IDE 与操作系统生成文件
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db